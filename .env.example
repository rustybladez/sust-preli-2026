# QueueStorm Investigator — environment template
# Copy to .env and fill in only the values you need.
# The service runs with NO changes from this template (rules + templates cover
# all 10 sample cases). Set USE_LLM=true plus a provider key only if you want
# the optional LLM-based text generation.

# --- Server --------------------------------------------------------------
PORT=8000
LOG_LEVEL=info

# --- LLM (optional) ------------------------------------------------------
USE_LLM=false
LLM_PROVIDER=gemini
LLM_TIMEOUT_SECONDS=8

# Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

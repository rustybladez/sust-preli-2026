PORT=8000
LOG_LEVEL=info

# LLM is optional — service runs fully on rules + templates when USE_LLM=false
USE_LLM=false
LLM_PROVIDER=gemini
LLM_TIMEOUT_SECONDS=8

# Gemini (free tier) — enable USE_LLM=true and set key to polish text fields
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional future provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
